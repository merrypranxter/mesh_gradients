{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mesh_gradients presets",
  "type": "object",
  "required": ["presets", "keymap"],
  "properties": {
    "presets": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/preset" }
    },
    "keymap": {
      "type": "object",
      "description": "keyboard key → preset id",
      "additionalProperties": { "type": "string" }
    }
  },
  "definitions": {
    "preset": {
      "type": "object",
      "required": ["engine", "colors"],
      "properties": {
        "label": { "type": "string" },
        "engine": {
          "type": "string",
          "enum": ["idw", "rbf", "coons", "gouraud", "voronoi_soft"]
        },
        "layout": {
          "type": "string",
          "enum": ["ring", "grid", "vertical"],
          "default": "ring"
        },
        "colors": {
          "type": "array",
          "minItems": 2,
          "maxItems": 12,
          "items": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
        },
        "params": {
          "type": "object",
          "properties": {
            "power": { "type": "number", "minimum": 1, "maximum": 4 },
            "radius": { "type": "number", "minimum": 0.05, "maximum": 1 },
            "softness": { "type": "number", "minimum": 0, "maximum": 0.5 }
          }
        },
        "warp": { "type": "number", "minimum": 0, "maximum": 1 },
        "drift": { "type": "number", "minimum": 0, "maximum": 1 },
        "post": {
          "type": "object",
          "properties": {
            "blur": { "type": "number", "minimum": 0, "maximum": 1 },
            "holo": { "type": "number", "minimum": 0, "maximum": 1 },
            "vignette": { "type": "number", "minimum": 0, "maximum": 1 },
            "grain": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    }
  }
}
